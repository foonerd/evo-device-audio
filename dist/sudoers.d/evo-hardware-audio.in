# sudoers drop-in template — installed by the bootstrap
# script at /etc/sudoers.d/evo-hardware-audio with mode
# 0440, owned root:root.
#
# Grants the steward service user (substituted at install
# time for the `@EVO_SERVICE_USER@` placeholder) NOPASSWD
# access to a path-scoped pair of commands the
# `org.evoframework.hardware.audio-config` plugin invokes:
#
# 1. `EVO_HARDWARE_AUDIO_READ` `Cmnd_Alias` — read access
#    to the host's boot-config file (`/boot/firmware/config.txt`
#    on Bookworm/Trixie + Pi default, `/boot/config.txt` on
#    older images). The plugin prefers a direct
#    `tokio::fs::read_to_string` first; this grant only
#    kicks in when the boot-config is not world-readable
#    (some hardened images).
#
# 2. `EVO_HARDWARE_AUDIO_WRITE` `Cmnd_Alias` — `tee`
#    against the boot-config locations and against the
#    Pi-specific i2c-dev modules-load.d drop-in
#    (`/etc/modules-load.d/evo-i2c-dev.conf`). The plugin
#    writes the banner-fenced managed `dtoverlay=` block via
#    `sudo -n tee` on every operator gesture against the
#    hardware.audio shelf.
#
# Both aliases are PATH-SCOPED. There is no broad sudo
# grant: the operator's audit log keeps full records on any
# command outside these aliases.
#
# Apply via the bootstrap script:
#   scripts/bootstrap.sh
#
# Or manually (substitute the placeholder):
#   sed 's/@EVO_SERVICE_USER@/<your-service-user>/' \
#       dist/sudoers.d/evo-hardware-audio.in \
#       | sudo install -m 0440 -o root -g root /dev/stdin \
#         /etc/sudoers.d/evo-hardware-audio
#
# `visudo -c -f /etc/sudoers.d/evo-hardware-audio` verifies
# syntactically valid sudoers.

Cmnd_Alias EVO_HARDWARE_AUDIO_READ = \
    /usr/bin/cat /boot/firmware/config.txt, \
    /usr/bin/cat /boot/config.txt

Cmnd_Alias EVO_HARDWARE_AUDIO_WRITE = \
    /usr/bin/tee /boot/firmware/config.txt, \
    /usr/bin/tee /boot/config.txt, \
    /usr/bin/tee /etc/modules-load.d/evo-i2c-dev.conf

@EVO_SERVICE_USER@ ALL=(root) NOPASSWD: EVO_HARDWARE_AUDIO_READ
@EVO_SERVICE_USER@ ALL=(root) NOPASSWD: EVO_HARDWARE_AUDIO_WRITE
